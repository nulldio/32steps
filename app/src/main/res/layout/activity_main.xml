<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground"
    android:fillViewport="true">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingTop="48dp"
    android:paddingBottom="32dp"
    android:focusable="true"
    android:focusableInTouchMode="true">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Volume"
        android:textColor="?colorOnSurface"
        android:textSize="20sp"
        android:fontFamily="sans-serif"
        android:layout_marginBottom="12dp"
        android:layout_marginStart="6dp" />

    <!-- Volume control card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="?colorSurfaceVariant"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="22dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_music"
                    android:layout_marginEnd="12dp"
                    android:contentDescription="Volume"
                    app:tint="?colorOnSurface" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Media"
                    android:textColor="?colorOnSurface"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/volume_counter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0/32"
                    android:textColor="?colorOnSurfaceVariant"
                    android:textSize="14sp"
                    android:layout_marginEnd="8dp" />

                <ImageView
                    android:id="@+id/btn_expand_app"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_expand"
                    app:tint="?colorOnSurfaceVariant"
                    android:contentDescription="Expand"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="2dp" />

            </LinearLayout>

            <SeekBar
                android:id="@+id/volume_seekbar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:max="32"
                android:progress="0"
                android:progressTint="?colorOnSurface"
                android:thumbTint="?colorOnSurface"
                android:progressBackgroundTint="?colorOnSurfaceVariant" />

            <!-- Expandable stream sliders -->
            <LinearLayout
                android:id="@+id/extra_sliders_app"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginTop="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="6dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Ring"
                        android:textColor="?colorOnSurface"
                        android:textSize="13sp" />
                    <TextView
                        android:id="@+id/ring_counter_app"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="?colorOnSurfaceVariant"
                        android:textSize="13sp" />
                </LinearLayout>

                <SeekBar
                    android:id="@+id/ring_slider_app"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:progressTint="?colorOnSurface"
                    android:thumbTint="?colorOnSurface"
                    android:progressBackgroundTint="?colorOnSurfaceVariant"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="6dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Notification"
                        android:textColor="?colorOnSurface"
                        android:textSize="13sp" />
                    <TextView
                        android:id="@+id/notif_counter_app"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="?colorOnSurfaceVariant"
                        android:textSize="13sp" />
                </LinearLayout>

                <SeekBar
                    android:id="@+id/notification_slider_app"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:progressTint="?colorOnSurface"
                    android:thumbTint="?colorOnSurface"
                    android:progressBackgroundTint="?colorOnSurfaceVariant"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="6dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Alarm"
                        android:textColor="?colorOnSurface"
                        android:textSize="13sp" />
                    <TextView
                        android:id="@+id/alarm_counter_app"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="?colorOnSurfaceVariant"
                        android:textSize="13sp" />
                </LinearLayout>

                <SeekBar
                    android:id="@+id/alarm_slider_app"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:progressTint="?colorOnSurface"
                    android:thumbTint="?colorOnSurface"
                    android:progressBackgroundTint="?colorOnSurfaceVariant"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="6dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Call"
                        android:textColor="?colorOnSurface"
                        android:textSize="13sp" />
                    <TextView
                        android:id="@+id/call_counter_app"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="?colorOnSurfaceVariant"
                        android:textSize="13sp" />
                </LinearLayout>

                <SeekBar
                    android:id="@+id/call_slider_app"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:progressTint="?colorOnSurface"
                    android:thumbTint="?colorOnSurface"
                    android:progressBackgroundTint="?colorOnSurfaceVariant" />

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Change Steps"
        android:textColor="?colorOnSurface"
        android:textSize="20sp"
        android:fontFamily="sans-serif"
        android:layout_marginBottom="12dp"
        android:layout_marginStart="6dp" />

    <!-- Steps input card — whole card taps to focus input -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/steps_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="?colorSurfaceVariant"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        android:clickable="true"
        android:focusable="true"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:paddingTop="18dp"
            android:paddingBottom="18dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Steps"
                android:textColor="?colorOnSurface"
                android:textSize="15sp" />

            <EditText
                android:id="@+id/steps_input"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:maxLength="4"
                android:textColor="?colorOnSurface"
                android:textColorHint="?colorOnSurfaceVariant"
                android:hint="32"
                android:background="@android:color/transparent"
                android:textSize="15sp"
                android:gravity="end"
                android:cursorVisible="false" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Sound Profile section -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sound Profile"
        android:textColor="?colorOnSurface"
        android:textSize="20sp"
        android:fontFamily="sans-serif"
        android:layout_marginBottom="12dp"
        android:layout_marginStart="6dp" />

    <!-- Preset list -->
    <LinearLayout
        android:id="@+id/preset_list"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical" />

    <!-- Search card - toggles between "Add headphones" and search input -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/search_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="?colorSurfaceVariant"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        android:layout_marginBottom="8dp">

        <!-- Add button (shown by default) -->
        <LinearLayout
            android:id="@+id/btn_add_preset"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_add"
                app:tint="?colorOnSurfaceVariant"
                android:layout_marginEnd="12dp"
                android:contentDescription="Add" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add headphones"
                android:textColor="?colorOnSurfaceVariant"
                android:textSize="15sp" />

        </LinearLayout>

        <!-- Search input (hidden by default) -->
        <EditText
            android:id="@+id/profile_search"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Search headphones..."
            android:inputType="text"
            android:textColor="?colorOnSurface"
            android:textColorHint="?colorOnSurfaceVariant"
            android:textSize="15sp"
            android:background="@android:color/transparent"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:visibility="gone" />

    </com.google.android.material.card.MaterialCardView>

    <!-- Search results (hidden by default) -->
    <LinearLayout
        android:id="@+id/search_results"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="12dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/permissions_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Permissions"
        android:textColor="?colorOnSurface"
        android:textSize="20sp"
        android:fontFamily="sans-serif"
        android:layout_marginBottom="12dp"
        android:layout_marginStart="6dp" />

    <!-- Status card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/status_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="?colorSurfaceVariant"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/status_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="?colorOnSurface"
            android:textSize="15sp"
            android:lineSpacingExtra="10dp"
            android:padding="22dp" />

    </com.google.android.material.card.MaterialCardView>

    <!-- Setup button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_setup"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Set up"
        android:textSize="15sp"
        app:cornerRadius="24dp" />

</LinearLayout>
</ScrollView>

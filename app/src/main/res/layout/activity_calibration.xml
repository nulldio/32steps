<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:colorBackground"
    android:gravity="center"
    android:padding="32dp">

    <TextView
        android:id="@+id/calibration_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Listening Test"
        android:textColor="?colorOnSurface"
        android:textSize="24sp"
        android:fontFamily="sans-serif"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/calibration_band"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="?colorOnSurfaceVariant"
        android:textSize="16sp"
        android:layout_marginBottom="24dp" />

    <TextView
        android:id="@+id/calibration_instruction"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="?colorOnSurfaceVariant"
        android:textSize="14sp"
        android:textAlignment="center"
        android:layout_marginBottom="40dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp" />

    <!-- A/B buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="32dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_a"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:text="A"
            android:textSize="32sp"
            app:cornerRadius="24dp"
            android:layout_marginEnd="24dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_b"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:text="B"
            android:textSize="32sp"
            app:cornerRadius="24dp" />

    </LinearLayout>

    <!-- Progress -->
    <ProgressBar
        android:id="@+id/calibration_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="100"
        android:progress="0"
        android:progressTint="?colorOnSurface"
        android:progressBackgroundTint="?colorOnSurfaceVariant"
        android:layout_marginBottom="24dp" />

    <!-- Action buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_confirm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Confirm"
            android:textSize="14sp"
            style="@style/Widget.Material3.Button.TextButton" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Redo"
            android:textSize="14sp"
            android:visibility="gone"
            style="@style/Widget.Material3.Button.TextButton" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_no_diff"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No difference"
            android:textSize="14sp"
            style="@style/Widget.Material3.Button.TextButton" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_skip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Skip"
            android:textSize="14sp"
            style="@style/Widget.Material3.Button.TextButton" />

    </LinearLayout>

</LinearLayout>

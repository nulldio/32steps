<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:colorBackground"
    android:gravity="center"
    android:padding="32dp">

    <TextView
        android:id="@+id/calibration_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Calibrating"
        android:textColor="?colorOnSurface"
        android:textSize="24sp"
        android:fontFamily="sans-serif"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/calibration_band"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bass (1/7)"
        android:textColor="?colorOnSurfaceVariant"
        android:textSize="16sp"
        android:layout_marginBottom="48dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Play some music, then pick which sounds better"
        android:textColor="?colorOnSurfaceVariant"
        android:textSize="14sp"
        android:textAlignment="center"
        android:layout_marginBottom="48dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="48dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_a"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:text="A"
            android:textSize="32sp"
            app:cornerRadius="24dp"
            android:layout_marginEnd="24dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_b"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:text="B"
            android:textSize="32sp"
            app:cornerRadius="24dp" />

    </LinearLayout>

    <ProgressBar
        android:id="@+id/calibration_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="100"
        android:progress="0"
        android:progressTint="?colorOnSurface"
        android:progressBackgroundTint="?colorOnSurfaceVariant"
        android:layout_marginBottom="24dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_skip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Skip band"
        android:textSize="14sp"
        style="@style/Widget.Material3.Button.TextButton" />

</LinearLayout>

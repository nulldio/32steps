<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/overlay_bg"
    android:padding="22dp">

    <!-- Media row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_music"
            android:layout_marginEnd="12dp"
            android:contentDescription="Volume"
            android:tint="@color/overlay_text" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Media"
            android:textColor="@color/overlay_text"
            android:textSize="15sp" />

        <ImageView
            android:id="@+id/btn_ringer"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_ring"
            android:tint="@color/overlay_text_secondary"
            android:contentDescription="Ringer mode"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="12dp" />

        <TextView
            android:id="@+id/step_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0/32"
            android:textColor="@color/overlay_text_secondary"
            android:textSize="14sp"
            android:layout_marginEnd="8dp" />

        <ImageView
            android:id="@+id/btn_expand"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_expand"
            app:tint="@color/overlay_text_secondary"
            android:contentDescription="Expand"
            android:clickable="true"
            android:focusable="true"
            android:padding="2dp" />

    </LinearLayout>

    <SeekBar
        android:id="@+id/step_progress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:max="32"
        android:progress="16"
        android:progressTint="@color/overlay_text"
        android:thumbTint="@color/overlay_text"
        android:progressBackgroundTint="@color/overlay_text_secondary"
        android:clickable="true"
        android:focusable="true" />

    <!-- Expandable section -->
    <LinearLayout
        android:id="@+id/extra_sliders"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:layout_marginTop="16dp">

        <!-- Ring -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Ring"
                android:textColor="@color/overlay_text"
                android:textSize="13sp" />
            <TextView
                android:id="@+id/ring_counter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/overlay_text_secondary"
                android:textSize="13sp" />
        </LinearLayout>

        <SeekBar
            android:id="@+id/ring_slider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:progressTint="@color/overlay_text"
            android:thumbTint="@color/overlay_text"
            android:progressBackgroundTint="@color/overlay_text_secondary"
            android:layout_marginBottom="12dp" />

        <!-- Notification -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Notification"
                android:textColor="@color/overlay_text"
                android:textSize="13sp" />
            <TextView
                android:id="@+id/notif_counter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/overlay_text_secondary"
                android:textSize="13sp" />
        </LinearLayout>

        <SeekBar
            android:id="@+id/notification_slider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:progressTint="@color/overlay_text"
            android:thumbTint="@color/overlay_text"
            android:progressBackgroundTint="@color/overlay_text_secondary"
            android:layout_marginBottom="12dp" />

        <!-- Alarm -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Alarm"
                android:textColor="@color/overlay_text"
                android:textSize="13sp" />
            <TextView
                android:id="@+id/alarm_counter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/overlay_text_secondary"
                android:textSize="13sp" />
        </LinearLayout>

        <SeekBar
            android:id="@+id/alarm_slider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:progressTint="@color/overlay_text"
            android:thumbTint="@color/overlay_text"
            android:progressBackgroundTint="@color/overlay_text_secondary" />

    </LinearLayout>

</LinearLayout>

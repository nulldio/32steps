<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/overlay_bg"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingTop="14dp"
    android:paddingBottom="14dp">

    <!-- Top row: Media label + step count -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <ImageView
            android:layout_width="15dp"
            android:layout_height="15dp"
            android:src="@drawable/ic_music"
            android:layout_marginEnd="8dp"
            android:contentDescription="Volume" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Media"
            android:textColor="#FFFFFFFF"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/step_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="16/32"
            android:textColor="#AAFFFFFF"
            android:textSize="13sp" />

    </LinearLayout>

    <!-- Volume slider — same style as setup screen -->
    <SeekBar
        android:id="@+id/step_progress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="32"
        android:progress="16"
        android:progressTint="#FFFFFFFF"
        android:thumbTint="#FFFFFFFF"
        android:progressBackgroundTint="#33FFFFFF"
        android:clickable="false"
        android:focusable="false" />

</LinearLayout>

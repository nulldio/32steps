<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground"
    android:fillViewport="true">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingTop="48dp"
    android:paddingBottom="32dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Device mappings"
        android:textColor="?colorOnSurface"
        android:textSize="20sp"
        android:fontFamily="sans-serif"
        android:layout_marginBottom="20dp"
        android:layout_marginStart="6dp" />

    <!-- Pair current device -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="?colorSurfaceVariant"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:paddingTop="18dp"
            android:paddingBottom="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pair current device"
                android:textColor="?colorOnSurface"
                android:textSize="15sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Detect connected headphones and assign a sound profile"
                android:textColor="?colorOnSurfaceVariant"
                android:textSize="12sp"
                android:layout_marginTop="4dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_pair_device"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="14dp"
                android:text="Detect and pair"
                android:textSize="13sp"
                style="@style/Widget.Material3.Button.TonalButton" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Saved mappings section header -->
    <TextView
        android:id="@+id/label_saved_mappings"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Saved mappings"
        android:textColor="?colorPrimary"
        android:textSize="13sp"
        android:fontFamily="sans-serif-medium"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="10dp"
        android:layout_marginStart="6dp"
        android:visibility="gone" />

    <!-- Empty state -->
    <TextView
        android:id="@+id/label_empty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="No device mappings yet. Connect headphones and tap the button above to get started."
        android:textColor="?colorOnSurfaceVariant"
        android:textSize="13sp"
        android:layout_marginStart="6dp"
        android:layout_marginTop="12dp" />

    <!-- Container for saved mapping rows -->
    <LinearLayout
        android:id="@+id/mappings_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical" />

</LinearLayout>
</ScrollView>

<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground"
    android:fillViewport="true">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingStart="48dp"
    android:paddingEnd="48dp"
    android:paddingTop="32dp"
    android:paddingBottom="32dp"
    android:baselineAligned="false">

    <!-- Left panel: Sound Profiles -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingEnd="24dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="32steps"
                android:textColor="?colorOnSurface"
                android:textSize="28sp"
                android:fontFamily="sans-serif" />

            <ImageView
                android:id="@+id/btn_settings"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_settings"
                app:tint="?colorOnSurfaceVariant"
                android:contentDescription="Settings"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sound Profile"
            android:textColor="?colorOnSurface"
            android:textSize="22sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="16dp" />

        <LinearLayout
            android:id="@+id/preset_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <!-- Add headphones -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btn_add_preset"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="?colorSurfaceVariant"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="18dp"
                android:paddingBottom="18dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_add"
                    app:tint="?colorOnSurfaceVariant"
                    android:layout_marginEnd="14dp"
                    android:contentDescription="Add" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Add headphones"
                    android:textColor="?colorOnSurfaceVariant"
                    android:textSize="18sp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Create custom profile -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btn_create_custom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="?colorSurfaceVariant"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="18dp"
                android:paddingBottom="18dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_music"
                    app:tint="?colorOnSurfaceVariant"
                    android:layout_marginEnd="14dp"
                    android:contentDescription="Create" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Create custom profile"
                    android:textColor="?colorOnSurfaceVariant"
                    android:textSize="18sp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Search -->
        <EditText
            android:id="@+id/profile_search"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Search headphones..."
            android:textSize="16sp"
            android:textColor="?colorOnSurface"
            android:textColorHint="?colorOnSurfaceVariant"
            android:background="@null"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:visibility="gone"
            android:focusable="true" />

        <LinearLayout
            android:id="@+id/search_results"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Right panel: EQ Presets + Info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="24dp">

        <!-- Hidden views needed by MainActivity code -->
        <SeekBar
            android:id="@+id/volume_seekbar"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />
        <TextView
            android:id="@+id/volume_counter"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />
        <EditText
            android:id="@+id/steps_input"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />
        <TextView
            android:id="@+id/status_text"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />
        <Button
            android:id="@+id/btn_setup"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="About"
            android:textColor="?colorOnSurface"
            android:textSize="22sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Select your headphones or speakers from 6000+ models to apply sound correction based on measured frequency response data from AutoEQ."
            android:textColor="?colorOnSurfaceVariant"
            android:textSize="16sp"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginBottom="24dp" />

        <!-- EQ Presets -->
        <LinearLayout
            android:id="@+id/eq_presets_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EQ Presets"
                android:textColor="?colorOnSurface"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:id="@+id/eq_preset_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
</ScrollView>
